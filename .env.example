# Required: OpenAI API key (for generation + RAGAS evaluation)
OPENAI_API_KEY=sk-proj-your-key-here

# Optional: HuggingFace token (for gated models like jina-v3)
HF_TOKEN=hf_your-token-here

# Optional: Custom LLM endpoint (empty = OpenAI default)
LLM_BASE_URL=

# Optional: FPT AI Marketplace
FPT_API_KEY=your-fpt-api-key-here
FPT_BASE_URL=https://mkp-api.fptcloud.com

# Optional: Query transform LLM model
TRANSFORM_LLM_MODEL=Llama-3.3-70B-Instruct
